# Supabase — get these from your Supabase project's Settings > API page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side only. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# OpenFDA API key — https://open.fda.gov/apis/authentication/
# Optional but strongly recommended (higher rate limits).
OPENFDA_API_KEY=

# Shared secret that protects /api/sync. Vercel Cron must send it as
# `Authorization: Bearer <CRON_SECRET>`. Generate with `openssl rand -hex 32`.
CRON_SECRET=

# SMTP — used for recall alert emails, password resets, signup verifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Operations alert recipient. Sync failures and other ops issues are emailed here.
OPS_ALERT_EMAIL=

# Public URL of the deployed app — used in email links (e.g. unsubscribe, reset).
NEXT_PUBLIC_APP_URL=http://localhost:4000

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs from Stripe Products (test mode)
STRIPE_PRICE_PERSONAL_MONTHLY=price_...
STRIPE_PRICE_PERSONAL_YEARLY=price_...
STRIPE_PRICE_FAMILY_MONTHLY=price_...
STRIPE_PRICE_FAMILY_YEARLY=price_...

# Refund unused Stripe customer credit when subscription ends (customer.subscription.deleted).
# Set STRIPE_REFUND_ON_CANCEL=false to disable. Minimum credit to refund (cents), default 100 ($1).
STRIPE_REFUND_ON_CANCEL=true
REFUND_MIN_CENTS=100
